# Backend
APP_NAME="AI Operations & Workflow Automation Platform"
APP_ENV=local
DATABASE_URL=postgresql+psycopg2://aiops:aiops@db:5432/aiops
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=60
DEMO_SEED_ENABLED=true
LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=ai-ops-workflow-platform

# Optional AI features
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_TIMEOUT_SECONDS=20
OPENAI_MAX_RETRIES=2
OPENAI_INPUT_COST_PER_1M=1.25
OPENAI_OUTPUT_COST_PER_1M=10.00

# Frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_DEMO_USERNAME=operator
